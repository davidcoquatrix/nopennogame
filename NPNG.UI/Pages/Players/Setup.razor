@page "/players"
@using NPNG.Domain.Entities
@inject NavigationManager NavigationManager
@implements IDisposable

<div class="app-header">
    <div style="display:flex;align-items:center;gap:8px">
        <button class="ico-btn" @onclick="GoBack">←</button>
        <span style="font-size:1.05rem;font-weight:700">@GameName — Joueurs</span>
    </div>
    <div style="font-size:.7rem;color:var(--sub);font-family:var(--font-mono)">@CurrentPlayerCount/8</div>
</div>

@if (GameState.CurrentSession != null && (GameState.CurrentSession.CurrentRound > 1 || GameState.CurrentSession.Scores.Any()))
{
    <div style="background:rgba(248, 113, 113, 0.1); border:1px solid rgba(248, 113, 113, 0.3); border-radius:11px; padding:12px; margin-bottom:12px; color:#F87171; font-size:0.8rem;">
        <strong>⚠️ Partie en cours</strong><br/>
        Ajouter ou retirer des joueurs maintenant peut décaler les scores existants. Procède avec prudence !
    </div>
}

<div class="section-label">Ordre et 1er joueur</div>

@if (GameState.CurrentSession == null || GameState.CurrentSession.Players.Length == 0)
{
    <div
        style="text-align:center;padding:20px;color:var(--sub);font-size:.85rem;border:1px dashed var(--bdr-md);border-radius:12px;margin-bottom:12px">
        Ajoute des joueurs pour commencer !
    </div>
}
else
{
    <div class="player-list">
        @{
            var playersList = GameState.CurrentSession.Players.OrderBy(p => p.DisplayOrder).ToList();
        }
        
        @for (int i = 0; i < playersList.Count; i++)
        {
            var player = playersList[i];
            var isFirstInList = i == 0;
            var isLastInList = i == playersList.Count - 1;

            <div class="player-row" @key="player.PlayerId">
                <div class="player-order-controls">
                    <button class="ico-btn move-btn" disabled="@isFirstInList" @onclick="() => MovePlayerUp(player.PlayerId)">▲</button>
                    <button class="ico-btn move-btn" disabled="@isLastInList" @onclick="() => MovePlayerDown(player.PlayerId)">▼</button>
                </div>
                <div class="player-avatar" style="border-color:@player.Color">@player.Emoji</div>

                <div style="flex:1;display:flex;flex-direction:column">
                    <span class="player-name">@player.Name</span>
                    @if (player.IsFirstPlayer && GameState.CurrentSession?.Template.Rules != null && GameState.CurrentSession.Template.Rules.FirstPlayerMechanic != NPNG.Domain.Enums.FirstPlayerMechanic.None)
                    {
                        <span style="font-size:.6rem;color:var(--accent);font-weight:700;letter-spacing:.05em">PREMIER JOUEUR</span>
                    }
                </div>

                @if (!player.IsFirstPlayer && GameState.CurrentSession?.Template.Rules != null && GameState.CurrentSession.Template.Rules.FirstPlayerMechanic != NPNG.Domain.Enums.FirstPlayerMechanic.None)
                {
                    <button class="ico-btn" style="width:28px;height:28px;font-size:.7rem"
                            title="Définir comme 1er joueur" @onclick="() => SetFirstPlayer(player.PlayerId)">🏁
                    </button>
                }
                
                <button class="ico-btn @(IsFavorite(player.Name) ? "star-active" : "")" style="width:28px;height:28px;font-size:.8rem; margin-left:4px;"
                        title="@(IsFavorite(player.Name) ? "Retirer des favoris" : "Ajouter aux favoris")"
                        @onclick="() => ToggleFavorite(player.Name, player.Emoji)">
                    @(IsFavorite(player.Name) ? "★" : "☆")
                </button>

                <button class="btn-danger" style="margin-left:4px" @onclick="() => RemovePlayer(player.PlayerId)">
                    ✕
                </button>
            </div>
        }
    </div>
}

<div class="section-label">Ajouter un joueur</div>
<div class="add-player-row">
    <input class="add-input" type="text" placeholder="Prénom…" @bind="newPlayerName" @bind:event="oninput"
           @onkeyup="HandleKeyUp"/>
    <button class="add-btn" @onclick="AddPlayer"
            disabled="@(string.IsNullOrWhiteSpace(newPlayerName) || CurrentPlayerCount >= 8)">＋ Ajouter
    </button>
</div>

<div
    style="background:var(--raised);border:1px solid var(--bdr-md);border-radius:11px;padding:9px 11px;margin-bottom:10px">
    <div class="section-label" style="margin-top:0">Emojis disponibles</div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
        @foreach (var emoji in availableEmojis)
        {
            <span style="font-size:1.4rem;cursor:pointer;opacity:@(selectedEmoji == emoji ? "1" : "0.5")"
                  @onclick="() => SelectEmoji(emoji)">@emoji</span>
        }
    </div>
</div>

@if (favoritePlayers.Any())
{
    <div class="section-label">Favoris</div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:15px">
        @foreach (var fav in favoritePlayers)
        {
            var isAlreadyInGame = GameState.CurrentSession?.Players.Any(p => p.Name.Equals(fav.Name, StringComparison.OrdinalIgnoreCase)) == true;
            <button class="fav-chip" 
                    @onclick="() => AddFavoritePlayerToGame(fav)" disabled="@(isAlreadyInGame || CurrentPlayerCount >= 8)">
                <span class="fav-emoji">@fav.DefaultEmoji</span>
                <span>@fav.Name</span>
            </button>
        }
    </div>
}

<button class="btn-cta" disabled="@(CurrentPlayerCount < 2)" @onclick="StartGame">
    Lancer la partie ▶
</button>

@code {
    [Inject] public GameStateService GameState { get; set; } = default!;
    [Inject] public NPNG.Application.Interfaces.IPlayerProfileRepository ProfileRepository { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "game")]
    public string? GameName { get; set; } = "Partie";

    private string newPlayerName = "";
    private string selectedEmoji = "🎯";
    
    private List<Player> favoritePlayers = new();

    private List<string> availableEmojis = new() { "🎯", "🦊", "🐉", "🌈", "⚡", "🍀", "🎸", "🎮", "🌟", "🔥", "💜", "🦄", "🚀", "🍕" };
    private List<string> availableColors = new() { "#7C9EBF", "#4ADE80", "var(--accent)", "#F87171", "#A78BFA", "#FCD34D", "#60A5FA", "#F472B6" };

    private int CurrentPlayerCount => GameState.CurrentSession?.Players.Length ?? 0;

    protected override async Task OnInitializedAsync()
    {
        GameState.OnStateChanged += StateHasChanged;

        // Si la session est nulle (par exemple après un F5), on essaie de la recharger depuis le LocalStorage
        if (GameState.CurrentSession == null)
        {
            var loaded = await GameState.LoadLatestActiveSessionAsync();
            if (!loaded)
            {
                // Si aucune session n'a pu être restaurée, on retourne à l'accueil
                NavigationManager.NavigateTo("/");
                return;
            }
        }

        if (CurrentPlayerCount == 0)
        {
            var profile = await ProfileRepository.GetDefaultProfileAsync();
            if (profile != null)
            {
                newPlayerName = profile.Name;
                if (availableEmojis.Contains(profile.DefaultEmoji))
                {
                    selectedEmoji = profile.DefaultEmoji;
                }
            }
        }
        
        await LoadFavoritesAsync();
    }
    
    private async Task LoadFavoritesAsync()
    {
        var favs = await ProfileRepository.GetFavoritePlayersAsync();
        favoritePlayers = favs.ToList();
    }
    
    private bool IsFavorite(string name)
    {
        return favoritePlayers.Any(f => f.Name.Equals(name, StringComparison.OrdinalIgnoreCase));
    }
    
    private async Task ToggleFavorite(string name, string emoji)
    {
        var existingFav = favoritePlayers.FirstOrDefault(f => f.Name.Equals(name, StringComparison.OrdinalIgnoreCase));
        if (existingFav != null)
        {
            await ProfileRepository.RemoveFavoritePlayerAsync(existingFav.Id);
        }
        else
        {
            await ProfileRepository.AddFavoritePlayerAsync(new Player(Guid.NewGuid(), name, emoji));
        }
        
        await LoadFavoritesAsync();
    }
    
    private async Task AddFavoritePlayerToGame(Player fav)
    {
        if (CurrentPlayerCount >= 8) return;
        var color = availableColors[CurrentPlayerCount % availableColors.Count];
        await GameState.AddPlayerToSetupAsync(fav.Name, fav.DefaultEmoji, color);
    }

    public void Dispose()
    {
        GameState.OnStateChanged -= StateHasChanged;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/");
    }

    private void SelectEmoji(string emoji)
    {
        selectedEmoji = emoji;
    }

    private async Task AddPlayer()
    {
        if (string.IsNullOrWhiteSpace(newPlayerName) || CurrentPlayerCount >= 8) return;

        var isFirstPlayerAdded = CurrentPlayerCount == 0;
        var color = availableColors[CurrentPlayerCount % availableColors.Count];
        
        await GameState.AddPlayerToSetupAsync(newPlayerName.Trim(), selectedEmoji, color);

        if (isFirstPlayerAdded)
        {
            await ProfileRepository.SaveDefaultProfileAsync(new NPNG.Domain.Entities.Player(Guid.NewGuid(), newPlayerName.Trim(), selectedEmoji));
        }

        newPlayerName = "";

        var rnd = new Random();
        selectedEmoji = availableEmojis[rnd.Next(availableEmojis.Count)];
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddPlayer();
        }
    }

    private async Task RemovePlayer(Guid playerId)
    {
        await GameState.RemovePlayerFromSetupAsync(playerId);
    }

    private async Task SetFirstPlayer(Guid playerId)
    {
        await GameState.SetFirstPlayerManuallyAsync(playerId);
    }

    private async Task MovePlayerUp(Guid playerId)
    {
        await GameState.MovePlayerUpAsync(playerId);
    }

    private async Task MovePlayerDown(Guid playerId)
    {
        await GameState.MovePlayerDownAsync(playerId);
    }

    private async Task StartGame()
    {
        await GameState.StartSessionAsync();
        NavigationManager.NavigateTo("/session");
    }

}
