@page "/players"
@using NPNG.Application.State
@inject NavigationManager NavigationManager
@implements IDisposable

<div class="app-header">
    <div style="display:flex;align-items:center;gap:8px">
        <button class="ico-btn" @onclick="GoBack">←</button>
        <span style="font-size:1.05rem;font-weight:700">@GameName — Joueurs</span>
    </div>
    <div style="font-size:.7rem;color:var(--sub);font-family:var(--font-mono)">@CurrentPlayerCount/8</div>
</div>

<div class="section-label">Ordre et 1er joueur</div>

@if (GameState.CurrentSession?.Players.Length == 0)
{
    <div
        style="text-align:center;padding:20px;color:var(--sub);font-size:.85rem;border:1px dashed var(--bdr-md);border-radius:12px;margin-bottom:12px">
        Ajoute des joueurs pour commencer !
    </div>
}
else
{
<div class="player-list">
        @{
            var playersList = GameState.CurrentSession!.Players.OrderBy(p => p.DisplayOrder).ToList();
        }
        
        @for (int i = 0; i < playersList.Count; i++)
        {
            var player = playersList[i];
            var isFirstInList = i == 0;
            var isLastInList = i == playersList.Count - 1;

            <div class="player-row" @key="player.PlayerId">
                <div class="player-order-controls">
                    <button class="ico-btn move-btn" disabled="@isFirstInList" @onclick="() => MovePlayerUp(player.PlayerId)">▲</button>
                    <button class="ico-btn move-btn" disabled="@isLastInList" @onclick="() => MovePlayerDown(player.PlayerId)">▼</button>
                </div>
                <div class="player-avatar" style="border-color:@player.Color">@player.Emoji</div>

                <div style="flex:1;display:flex;flex-direction:column">
                    <span class="player-name">@player.Name</span>
                    @if (player.IsFirstPlayer)
                    {
                        <span style="font-size:.6rem;color:var(--accent);font-weight:700;letter-spacing:.05em">PREMIER JOUEUR</span>
                    }
                </div>

                @if (!player.IsFirstPlayer)
                {
                    <button class="ico-btn" style="width:28px;height:28px;font-size:.7rem"
                            title="Définir comme 1er joueur" @onclick="() => SetFirstPlayer(player.PlayerId)">🏁
                    </button>
                }

                <button class="btn-danger" style="margin-left:4px" @onclick="() => RemovePlayer(player.PlayerId)">
                    ✕
                </button>
            </div>
        }
    </div>
}

<div class="section-label">Ajouter un joueur</div>
<div class="add-player-row">
    <input class="add-input" type="text" placeholder="Prénom…" @bind="newPlayerName" @bind:event="oninput"
           @onkeyup="HandleKeyUp"/>
    <button class="add-btn" @onclick="AddPlayer"
            disabled="@(string.IsNullOrWhiteSpace(newPlayerName) || CurrentPlayerCount >= 8)">＋ Ajouter
    </button>
</div>

<div
    style="background:var(--raised);border:1px solid var(--bdr-md);border-radius:11px;padding:9px 11px;margin-bottom:10px">
    <div class="section-label" style="margin-top:0">Emojis disponibles</div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
        @foreach (var emoji in availableEmojis)
        {
            <span style="font-size:1.4rem;cursor:pointer;opacity:@(selectedEmoji == emoji ? "1" : "0.5")"
                  @onclick="() => SelectEmoji(emoji)">@emoji</span>
        }
    </div>
</div>

<button class="btn-cta" disabled="@(CurrentPlayerCount < 2)" @onclick="StartGame">
    Lancer la partie ▶
</button>

@code {
    [Inject] public GameStateService GameState { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "game")]
    public string? GameName { get; set; } = "Partie";

    private string newPlayerName = "";
    private string selectedEmoji = "🎯";

    private List<string> availableEmojis = new() { "🎯", "🦊", "🐉", "🌈", "⚡", "🍀", "🎸", "🎮", "🌟", "🔥", "💜", "🦄", "🚀", "🍕" };
    private List<string> availableColors = new() { "#7C9EBF", "#4ADE80", "var(--accent)", "#F87171", "#A78BFA", "#FCD34D", "#60A5FA", "#F472B6" };

    private int CurrentPlayerCount => GameState.CurrentSession?.Players.Length ?? 0;

    protected override void OnInitialized()
    {
        GameState.OnStateChanged += StateHasChanged;

        // Populate with mock players ONLY if empty (to speed up testing, remove for prod later)
        if (GameState.CurrentSession != null && GameState.CurrentSession.Players.Length == 0)
        {
            GameState.AddPlayerToSetup("Dylan", "🎮", "#7C9EBF");
            GameState.AddPlayerToSetup("Bob", "🌟", "#4ADE80");
        }
    }

    public void Dispose()
    {
        GameState.OnStateChanged -= StateHasChanged;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/");
    }

    private void SelectEmoji(string emoji)
    {
        selectedEmoji = emoji;
    }

    private void AddPlayer()
    {
        if (string.IsNullOrWhiteSpace(newPlayerName) || CurrentPlayerCount >= 8) return;

        var color = availableColors[CurrentPlayerCount % availableColors.Count];
        GameState.AddPlayerToSetup(newPlayerName.Trim(), selectedEmoji, color);

        newPlayerName = "";

        var rnd = new Random();
        selectedEmoji = availableEmojis[rnd.Next(availableEmojis.Count)];
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddPlayer();
        }
    }

    private void RemovePlayer(Guid playerId)
    {
        GameState.RemovePlayerFromSetup(playerId);
    }

    private void SetFirstPlayer(Guid playerId)
    {
        GameState.SetFirstPlayerManually(playerId);
    }

    private void MovePlayerUp(Guid playerId)
    {
        GameState.MovePlayerUp(playerId);
    }

    private void MovePlayerDown(Guid playerId)
    {
        GameState.MovePlayerDown(playerId);
    }

    private void StartGame()
    {
        NavigationManager.NavigateTo("/session");
    }

}
