@page "/"
@using NPNG.Domain.Enums

<!-- Header de la page d'accueil -->
<div class="app-header">
    <div class="logo">
        <div class="logo-ico">🎲</div>
        <span class="logo-txt">NPNG</span>
    </div>
</div>

@if (GameState.CurrentSession != null && GameState.CurrentSession.Status == SessionStatus.Active)
{
    <div style="background:var(--bg-accent-light); border:1px solid var(--accent); border-radius:12px; padding:16px; margin-bottom:20px; display:flex; align-items:center; justify-content:space-between; cursor:pointer;" @onclick="ResumeActiveSession">
        <div>
            <div style="color:var(--accent); font-weight:700; font-size:0.9rem; margin-bottom:4px;">Partie en cours</div>
            <div style="color:var(--txt); font-weight:600; font-size:1.1rem;">@GameState.CurrentSession.Template.Name</div>
            <div style="color:var(--sub); font-size:0.8rem; margin-top:2px;">Tour @GameState.CurrentSession.CurrentRound • @GameState.CurrentSession.Players.Length joueurs</div>
        </div>
        <div style="font-size:1.5rem; color:var(--accent);">▶</div>
    </div>
}

<div class="gp-header">
    <h2 class="gp-title">Nouvelle partie</h2>
    <p class="gp-sub">Choisis un jeu pour commencer</p>
</div>

<p class="section-lbl">Jeux disponibles</p>

<div class="catalogue" role="listbox" aria-label="Sélection du jeu">
    @foreach (var game in games)
    {
        var isSelected = selectedGame?.Id == game.Id;
        
        <button class="game-tile @(isSelected ? "selected" : "") @(game.IsCustom ? "custom" : "")" 
                role="option" 
                aria-selected="@isSelected.ToString().ToLower()" 
                @onclick="() => SelectGame(game)">
            
            <div class="tile-check" aria-hidden="true">✓</div>
            
            @if (!game.IsCustom)
            {
                <div class="tile-dot" style="background:@game.Color"></div>
            }

            <span class="tile-emoji">@game.Emoji</span>

            @if (game.IsCustom)
            {
                <div class="custom-text">
                    <div class="tile-name">@game.Name</div>
                    <div class="tile-rule">@game.Badge</div>
                </div>
            }
            else
            {
                <div class="tile-name">@game.Name</div>
                <div class="tile-rule">@game.Badge</div>
            }
        </button>
    }
</div>

@if (selectedGame != null)
{
    <div class="game-info-wrapper">
        <div class="game-info" role="status" aria-live="polite" @key="selectedGame.Id">
            <span class="game-info-emoji">@selectedGame.Emoji</span>
            <div class="game-info-body">
                <div class="game-info-name">@selectedGame.Name</div>
                <div class="game-info-desc">@selectedGame.Description</div>
            </div>
            <span class="game-info-badge">@selectedGame.Badge</span>
        </div>
    </div>
}

<button class="btn-cta" disabled="@(selectedGame == null)" @onclick="ContinueToSetup">
    Continuer &nbsp;→
</button>

@code {
    [Inject] public NavigationManager NavigationManager { get; set; } = default!;
    [Inject] public NPNG.Application.State.GameStateService GameState { get; set; } = default!;

    public record GameViewModel(Guid Id, string Emoji, string Name, string Description, string Badge, string Color, NPNG.Domain.Enums.ScoreType ScoreType, NPNG.Domain.Entities.GameRules? Rules = null, bool IsCustom = false);

    private List<GameViewModel> games = new()
    {
        new(Guid.Parse("11111111-1111-1111-1111-111111111111"), "🃏", "Skyjo", "Cartes −2 à 12. Chaque joueur révèle ses cartes. Le total le plus bas gagne. La partie s'arrête dès qu'un joueur atteint 100 pts.", "Le + bas gagne", "#7C9EBF", NPNG.Domain.Enums.ScoreType.CumulativeLower, new NPNG.Domain.Entities.GameRules(TargetScore: 100)),
        new(Guid.Parse("22222222-2222-2222-2222-222222222222"), "🂡", "Rami", "Défausser toutes ses cartes en formant des combinaisons. Le joueur avec le score cumulé le plus élevé en fin de manche gagne.", "Le + haut gagne", "#4ADE80", NPNG.Domain.Enums.ScoreType.Cumulative),
        new(Guid.Parse("33333333-3333-3333-3333-333333333333"), "🎴", "Uno", "Se débarrasser de toutes ses cartes en premier. Les cartes restantes en main sont comptées comme points de pénalité.", "Le + bas gagne", "#F87171", NPNG.Domain.Enums.ScoreType.CumulativeLower),
        new(Guid.Parse("44444444-4444-4444-4444-444444444444"), "🏛️", "Accropolis", "Construire une cité en posant des tuiles par catégories. Chaque catégorie a son propre système de points. Le plus haut total gagne.", "Structuré", "var(--accent)", NPNG.Domain.Enums.ScoreType.Structured),
        new(Guid.Parse("55555555-5555-5555-5555-555555555555"), "⚙️", "Jeu personnalisé", "Définis ton propre nom de jeu, la règle de victoire (+ haut ou + bas) et les limites optionnelles de score ou de tours.", "Personnalisé", "", NPNG.Domain.Enums.ScoreType.Cumulative, null, true)
    };

    private GameViewModel? selectedGame;

    protected override async Task OnInitializedAsync()
    {
        GameState.OnStateChanged += StateHasChanged;
        
        if (GameState.CurrentSession == null)
        {
            await GameState.LoadLatestActiveSessionAsync();
        }
        
        selectedGame = games.First();
    }
    
    public void Dispose()
    {
        GameState.OnStateChanged -= StateHasChanged;
    }

    private void SelectGame(GameViewModel game)
    {
        selectedGame = game;
    }
    
    private void ResumeActiveSession()
    {
        if (GameState.CurrentSession != null)
        {
            if (GameState.CurrentSession.CurrentRound == 1 && !GameState.CurrentSession.Scores.Any())
            {
                NavigationManager.NavigateTo($"/players?game={Uri.EscapeDataString(GameState.CurrentSession.Template.Name)}");
            }
            else
            {
                NavigationManager.NavigateTo("/session");
            }
        }
    }

    private async Task ContinueToSetup()
    {
        if (selectedGame != null)
        {
            if (selectedGame.IsCustom)
            {
                NavigationManager.NavigateTo($"/custom-game");
            }
            else
            {
                var template = new NPNG.Domain.Entities.GameTemplate(selectedGame.Id, selectedGame.Name, selectedGame.ScoreType, selectedGame.Description, selectedGame.Rules);
                await GameState.InitializeNewSessionAsync(template);
                NavigationManager.NavigateTo($"/players?game={Uri.EscapeDataString(selectedGame.Name)}");
            }
        }
    }
}
