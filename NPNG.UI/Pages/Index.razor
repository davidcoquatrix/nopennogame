@page "/"

<!-- Header de la page d'accueil -->
<div class="app-header">
    <div class="logo">
        <div class="logo-ico">🎲</div>
        <span class="logo-txt">NPNG</span>
    </div>
</div>

@if (GameState.CurrentSession != null && GameState.CurrentSession.Status == SessionStatus.Active)
{
    <div class="active-session-banner" @onclick="ResumeActiveSession">
        <div class="banner-content">
            <div class="banner-title">Partie en cours</div>
            <div class="banner-game-name">@GameState.CurrentSession.Template.Name</div>
            <div class="banner-details">Tour @GameState.CurrentSession.CurrentRound • @GameState.CurrentSession.Players.Length joueurs</div>
        </div>
        <div class="banner-actions">
            <button class="btn-abandon" @onclick="TryAbandonSession" @onclick:stopPropagation="true" aria-label="Abandonner la partie">
                🗑️
            </button>
            <div class="banner-icon">▶</div>
        </div>
    </div>
}

<div class="gp-header">
    <h2 class="gp-title">Nouvelle partie</h2>
    <p class="gp-sub">Choisis un jeu pour commencer</p>
</div>

<p class="section-lbl">Jeux disponibles</p>

<div class="catalogue" role="listbox" aria-label="Sélection du jeu">
    @foreach (var game in games)
    {
        var isSelected = selectedGame?.Id == game.Id;
        
        <button class="game-tile @(isSelected ? "selected" : "") @(game.IsCustom ? "custom" : "")" 
                role="option" 
                aria-selected="@isSelected.ToString().ToLower()" 
                @onclick="() => SelectGame(game)">
            
            <div class="tile-check" aria-hidden="true">✓</div>
            
            @if (!game.IsCustom)
            {
                <div class="tile-dot" style="background:@game.Color"></div>
            }

            <span class="tile-emoji">@game.Emoji</span>

            @if (game.IsCustom)
            {
                <div class="custom-text">
                    <div class="tile-name">@game.Name</div>
                    <div class="tile-rule">@game.Badge</div>
                </div>
                @if (game.Id != Guid.Parse("55555555-5555-5555-5555-555555555555"))
                {
                    <div class="delete-game-btn" @onclick="() => TryDeleteCustomGame(game.Id)" @onclick:stopPropagation="true">
                        ✕
                    </div>
                }
            }
            else
            {
                <div class="tile-name">@game.Name</div>
                <div class="tile-rule">@game.Badge</div>
            }
        </button>
    }
</div>

@if (selectedGame != null)
{
    <div class="game-info-wrapper">
        <div class="game-info" role="status" aria-live="polite" @key="selectedGame.Id">
            <span class="game-info-emoji">@selectedGame.Emoji</span>
            <div class="game-info-body">
                <div class="game-info-name">@selectedGame.Name</div>
                <div class="game-info-desc">@selectedGame.Description</div>
            </div>
            <span class="game-info-badge">@selectedGame.Badge</span>
        </div>
    </div>
}

<button class="btn-cta" disabled="@(selectedGame == null)" @onclick="TryContinueToSetup">
    Continuer &nbsp;→
</button>

@if (showOverwriteConfirm)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <h3 class="modal-title">⚠️ Partie en cours</h3>
            <p class="modal-desc">
                Lancer une nouvelle partie remplacera la partie de <strong>@GameState.CurrentSession?.Template.Name</strong> actuellement en cours.
            </p>
            <div class="modal-actions">
                <button class="btn-cta modal-danger-btn" @onclick="ConfirmAndContinue">Écraser et continuer</button>
                <button class="btn-secondary" @onclick="CancelOverwrite">Annuler</button>
            </div>
        </div>
    </div>
}

@if (showAbandonConfirm)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <h3 class="modal-title">🗑️ Abandonner la partie</h3>
            <p class="modal-desc">
                Êtes-vous sûr de vouloir abandonner la partie de <strong>@GameState.CurrentSession?.Template.Name</strong> ?
            </p>
            <div class="modal-actions">
                <button class="btn-cta modal-danger-btn" @onclick="ConfirmAbandon">Oui, abandonner</button>
                <button class="btn-secondary" @onclick="CancelAbandon">Annuler</button>
            </div>
        </div>
    </div>
}

@code {
    [Inject] public NavigationManager NavigationManager { get; set; } = default!;
    [Inject] public NPNG.Application.State.GameStateService GameState { get; set; } = default!;
    [Inject] public NPNG.Application.Interfaces.IGameCatalogueService GameCatalogue { get; set; } = default!;

    private IEnumerable<NPNG.Application.Models.GameCatalogueItem> games = Array.Empty<NPNG.Application.Models.GameCatalogueItem>();
    private NPNG.Application.Models.GameCatalogueItem? selectedGame;
    private bool showOverwriteConfirm = false;
    private bool showAbandonConfirm = false;

    protected override async Task OnInitializedAsync()
    {
        GameState.OnStateChanged += StateHasChanged;
        
        if (GameState.CurrentSession == null)
        {
            await GameState.LoadLatestActiveSessionAsync();
        }
        
        await LoadGamesAsync();
    }
    
    private async Task LoadGamesAsync()
    {
        games = await GameCatalogue.GetAvailableGamesAsync();
        if (selectedGame == null || !games.Any(g => g.Id == selectedGame.Id))
        {
            selectedGame = games.FirstOrDefault();
        }
    }
    
    public void Dispose()
    {
        GameState.OnStateChanged -= StateHasChanged;
    }

    private void SelectGame(NPNG.Application.Models.GameCatalogueItem game)
    {
        selectedGame = game;
    }
    
    private async Task TryDeleteCustomGame(Guid id)
    {
        await GameCatalogue.DeleteCustomGameAsync(id);
        await LoadGamesAsync();
    }
    
    private void TryAbandonSession()
    {
        showAbandonConfirm = true;
    }

    private void CancelAbandon()
    {
        showAbandonConfirm = false;
    }

    private async Task ConfirmAbandon()
    {
        showAbandonConfirm = false;
        await GameState.AbandonSessionAsync();
    }
    
    private void ResumeActiveSession()
    {
        if (GameState.CurrentSession != null)
        {
            if (GameState.CurrentSession.CurrentRound == 1 && !GameState.CurrentSession.Scores.Any())
            {
                NavigationManager.NavigateTo($"/players?game={Uri.EscapeDataString(GameState.CurrentSession.Template.Name)}");
            }
            else
            {
                NavigationManager.NavigateTo("/session");
            }
        }
    }

    private void TryContinueToSetup()
    {
        if (GameState.CurrentSession != null && GameState.CurrentSession.Status == SessionStatus.Active)
        {
            showOverwriteConfirm = true;
        }
        else
        {
            _ = ConfirmAndContinue();
        }
    }

    private void CancelOverwrite()
    {
        showOverwriteConfirm = false;
    }

    private async Task ConfirmAndContinue()
    {
        showOverwriteConfirm = false;
        if (selectedGame != null)
        {
            if (selectedGame.IsCustom && selectedGame.Id == Guid.Parse("55555555-5555-5555-5555-555555555555"))
            {
                NavigationManager.NavigateTo($"/custom-game");
            }
            else
            {
                var template = selectedGame.ToGameTemplate();
                await GameState.InitializeNewSessionAsync(template);
                NavigationManager.NavigateTo($"/players?game={Uri.EscapeDataString(selectedGame.Name)}");
            }
        }
    }
}
