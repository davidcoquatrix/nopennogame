@page "/session"
@using NPNG.Domain.Services
@using NPNG.Domain.Models
@inject NavigationManager NavigationManager
@inject GameStateService GameState
@inject IJSRuntime JsRuntime
@implements IDisposable

@if (GameState.CurrentSession == null)
{
    <div style="padding:20px;text-align:center;color:var(--sub)">Aucune session en cours...</div>
}
else if (GameState.CurrentSession.Status == SessionStatus.Finished)
{
    <div class="app-header">
        <div style="display:flex;align-items:center;gap:8px">
            <button class="ico-btn" @onclick="GoBack">←</button>
            <span style="font-size:1.05rem;font-weight:700">@GameState.CurrentSession.Template.Name</span>
        </div>
    </div>

    <div class="end-panel">
        <h2 class="end-panel-title">🎉 Partie Terminée !</h2>
        <p class="end-panel-desc">
            @if (!GameState.CurrentSession.RulesOverridden && GameState.CurrentSession.Template.Rules?.TargetScore.HasValue == true)
            {
                <span>L'objectif de @GameState.CurrentSession.Template.Rules.TargetScore pts a été atteint.</span>
            }
            else if (!GameState.CurrentSession.RulesOverridden && GameState.CurrentSession.Template.Rules?.MaxRounds.HasValue == true)
            {
                <span>La limite de @GameState.CurrentSession.Template.Rules.MaxRounds tours a été atteinte.</span>
            }
            else
            {
                <span>La partie a été terminée manuellement.</span>
            }
        </p>
    </div>

    <!-- CLASSEMENT FINAL -->
    <div class="section-label">Classement Final</div>
    <div class="leaderboard">
        @foreach (var pScore in leaderboard)
        {
            var player = GameState.CurrentSession.Players.First(p => p.PlayerId == pScore.PlayerId);
            var isLeader = pScore.Rank == 1;

            <div class="leaderboard-row @(isLeader ? "lead" : "")">
                <span class="rank">@pScore.Rank</span>
                <div class="av-m" style="@(isLeader ? "border-color:var(--accent)" : "")">@player.Emoji</div>
                <div class="leaderboard-info">
                    <div class="leaderboard-name">@player.Name</div>
                </div>

                @if (isLeader)
                {
                    <span class="db best">vainqueur</span>
                }
                else
                {
                    var bestScore = leaderboard.First().TotalScore;
                    var diff = pScore.TotalScore - bestScore;
                    <span class="db pos">@(diff > 0 ? "+" : "")@diff</span>
                }

                <div class="tot">@pScore.TotalScore</div>
            </div>
        }
    </div>

    <button class="btn-cta" style="margin-top:20px" @onclick="GoToHome">Retour à l'accueil</button>
    <button class="btn-secondary" @onclick="ResumeSession">Continuer la partie quand même</button>
}
else
{
    <div class="app-header">
        <div style="display:flex;align-items:center;gap:8px">
            <button class="ico-btn" @onclick="GoBack">←</button>
            <span style="font-size:1.05rem;font-weight:700">@GameState.CurrentSession.Template.Name</span>
        </div>
        <div style="display:flex;align-items:center;gap:6px">
            <span
                style="font-size:.65rem;font-family:var(--font-mono);color:var(--sub)">T.@(GameState.CurrentSession.CurrentRound.ToString("D2"))</span>
            <button class="ico-btn" style="font-size:.75rem" title="Time Travel" @onclick="GoToTimeTravel">⏪</button>
            <button class="ico-btn" style="font-size:.75rem; color:var(--danger);" title="Terminer"
                    @onclick="FinishSession">🏁
            </button>
        </div>
    </div>

    <!-- LIVE LEADERBOARD -->
    <div class="section-label">Classement</div>
    <div class="leaderboard">
        @foreach (var pScore in leaderboard)
        {
            var player = GameState.CurrentSession.Players.First(p => p.PlayerId == pScore.PlayerId);
            var isLeader = pScore.Rank == 1;

            <div class="leaderboard-row @(isLeader ? "lead" : "")">
                <span class="rank">@pScore.Rank</span>
                <div class="av-m" style="@(isLeader ? "border-color:var(--accent)" : "")">@player.Emoji</div>
                <div class="leaderboard-info">
                    <div class="leaderboard-name">@player.Name</div>
                    <div class="pips">
                        @{
                            var playerScores = GameState.CurrentSession.Scores.Where(s => s.PlayerId == player.PlayerId).OrderBy(s => s.Round);
                            foreach (var score in playerScores)
                            {
                                <span class="pip">@(score.Value > 0 ? "+" : "")@score.Value</span>
                            }
                        }
                    </div>
                </div>

                @if (isLeader)
                {
                    <span class="db best">meilleur</span>
                }
                else
                {
                    var bestScore = leaderboard.First().TotalScore;
                    var diff = pScore.TotalScore - bestScore;
                    <span class="db pos">@(diff > 0 ? "+" : "")@diff</span>
                }

                <div class="tot">@pScore.TotalScore</div>
            </div>
        }
    </div>

    <!-- ENTRY PANEL -->
    <div class="section-label">Saisie — Tour @GameState.CurrentSession.CurrentRound</div>
    <div class="entry-panel">
        @foreach (var player in GameState.CurrentSession.Players.OrderBy(p => p.DisplayOrder))
        {
            var hasMechanic = GameState.CurrentSession.Template?.Rules != null
                                  && GameState.CurrentSession.Template.Rules.FirstPlayerMechanic != NPNG.Domain.Enums.FirstPlayerMechanic.None;
            var showFirstPlayerBadge = player.IsFirstPlayer && hasMechanic;

            <div class="entry-row">
                <div class="entry-avatar">@player.Emoji</div>
                <div style="display:flex;flex-direction:column;flex:1;">
                    <span class="entry-name" style="flex:unset;">@player.Name</span>
                    @if (showFirstPlayerBadge)
                    {
                        <span style="font-size:.6rem;color:var(--accent);font-weight:700;letter-spacing:.05em">1ER JOUEUR</span>
                    }
                </div>
                <div class="score-controls">
                    <button class="score-button lrg" @onclick="() => AdjustScore(player.PlayerId, -10)">−10</button>
                    <button class="score-button lrg" @onclick="() => AdjustScore(player.PlayerId, -1)">−1</button>
                    <input type="number" class="score-value"
                           value="@(currentInputs.ContainsKey(player.PlayerId) ? currentInputs[player.PlayerId] : 0)"
                           @onchange="@(e=> OnScoreInputChange(player.PlayerId, e))"
                           @onfocus="async e => await ClearText(e)"
                           inputmode="numeric"/>
                    <button class="score-button slrg" @onclick="() => AdjustScore(player.PlayerId, 1)">+1</button>
                    <button class="score-button slrg" @onclick="() => AdjustScore(player.PlayerId, 10)">+10</button>
                    </div>
                    </div>
                    }

                    <button class="validate-btn" @onclick="ValidateRound">✓ &nbsp;Valider le
                    tour @GameState.CurrentSession.CurrentRound</button>
                    </div>
                    }

                    @code {
                    [Inject] public IJSRuntime JSRuntime { get; set; } = default!;

                    private Dictionary<Guid, int> currentInputs = new();
                    private List<PlayerScore> leaderboard = new();
    {
        GameState.OnStateChanged += HandleStateChanged;

        if (GameState.CurrentSession == null)
        {
            var loaded = await GameState.LoadLatestActiveSessionAsync();
            if (!loaded)
            {
                NavigationManager.NavigateTo("");
                return;
            }
        }

        UpdateState();
    }

    public void Dispose()
    {
        GameState.OnStateChanged -= HandleStateChanged;
    }

    private void HandleStateChanged()
    {
        UpdateState();
        StateHasChanged();
    }

    private void UpdateState()
    {
        if (GameState.CurrentSession != null)
        {
            var playerIds = GameState.CurrentSession.Players.Select(p => p.PlayerId);
            leaderboard = ScoreCalculator.CalculateLeaderboard(
                GameState.CurrentSession.Template.ScoreType,
                playerIds,
                GameState.CurrentSession.Scores).ToList();

            // S'assurer que chaque joueur a une entrée initialisée pour le tour en cours
            foreach (var p in GameState.CurrentSession.Players)
            {
                if (!currentInputs.ContainsKey(p.PlayerId))
                {
                    currentInputs[p.PlayerId] = 0;
                }
            }
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("players");
    }

    private void GoToHome()
    {
        NavigationManager.NavigateTo("");
    }

    private void GoToTimeTravel()
    {
        NavigationManager.NavigateTo("session/history");
    }

    private void AdjustScore(Guid playerId, int amount)
    {
        if (currentInputs.ContainsKey(playerId))
        {
            currentInputs[playerId] += amount;
        }
    }

    private void OnScoreInputChange(Guid playerId, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var result))
        {
            currentInputs[playerId] = result;
        }
    }

    private async Task ValidateRound()
    {
        if (GameState.CurrentSession == null) return;

        int currentRound = GameState.CurrentSession.CurrentRound;

        // On enregistre tous les scores saisis
        foreach (var input in currentInputs)
        {
            await GameState.RecordScoreAsync(input.Key, currentRound, input.Value);
        }

        // On passe au tour suivant (ce qui mettra à jour le 1er joueur)
        await GameState.AdvanceToNextRoundAsync();

        // On remet les compteurs à 0 pour le prochain tour
        foreach (var key in currentInputs.Keys.ToList())
        {
            currentInputs[key] = 0;
        }
    }

    private async Task ResumeSession()
    {
        await GameState.ResumeSessionAsync();
    }

    private async Task SelectText(FocusEventArgs e)
    {
        await JsRuntime.InvokeVoidAsync("selectActiveText");
    }

    private async Task FinishSession()
    {
        await GameState.FinishSessionAsync();
    }

}
