@page "/session/history"
@using NPNG.Domain.Models
@using NPNG.Domain.Services
@using System.Linq
@inject GameStateService GameState

<div class="app-header">
    <div class="header-nav">
        <BackButton />
        <span class="header-title">@(GameState.CurrentSession?.Template.Name ?? "Historique")</span>
    </div>
    <div class="header-subtitle">⏪ Mode édition</div>
</div>

@if (GameState.CurrentSession == null || maxCompletedRound < 1)
{
    <div class="empty-state">
        <div class="empty-icon">⏳</div>
        <div class="empty-text">Aucun tour terminé à modifier pour le moment.</div>
        <button class="primary-btn mt-15" @onclick="GoBack">Retour</button>
    </div>
}
else
{
    <!-- warning banner -->
    <div class="tt-banner">
        <span class="ico">⚠️</span>
        <span class="txt">Mode Time Travel — Modification d'un tour passé. Le classement sera recalculé.</span>
    </div>

    <!-- tour nav -->
    <div class="section-label">Sélectionner un tour</div>
    <div class="tt-nav">
        @for (int i = 1; i <= maxCompletedRound; i++)
        {
            var roundNum = i;
            var isCurrent = roundNum == editingRound;
            
            <div class="tt-btn @(isCurrent ? "cur" : "")" @onclick="() => SelectRound(roundNum)">
                T.@roundNum
            </div>
        }
    </div>

    <!-- editable score grid -->
    <div class="section-label">Scores — Tour @editingRound</div>
    <div class="table-container">
        <table class="round-table editing-mode">
            <thead>
                <tr>
                    <th>Joueur</th>
                    @for (int i = 1; i <= maxCompletedRound; i++)
                    {
                        if (i == editingRound)
                        {
                            <th class="editing-col-header">T.@i ✎</th>
                        }
                        else
                        {
                            <th>T.@i</th>
                        }
                    }
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var player in GameState.CurrentSession.Players.OrderBy(p => p.DisplayOrder))
                {
                    var isLeader = leaderboard.FirstOrDefault()?.PlayerId == player.PlayerId;

                    <tr>
                        <td>@player.Emoji @player.Name</td>
                        @for (int i = 1; i <= maxCompletedRound; i++)
                        {
                            if (i == editingRound)
                            {
                                <td class="editable-col">
                                    <span class="score-value score-value-warn">@(tempScores.GetValueOrDefault(player.PlayerId, 0))</span>
                                </td>
                            }
                            else
                            {
                                <td>@(GetScoreForRound(player.PlayerId, i))</td>
                            }
                        }
                        <td class="total-cell @(isLeader ? "lead" : "")">
                            @GetProjectedTotalScore(player.PlayerId)
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- correction in progress -->
    <div class="entry-panel">
        <div class="entry-panel-label">Correction — Tour @editingRound</div>
        
        @foreach (var player in GameState.CurrentSession.Players.OrderBy(p => p.DisplayOrder))
        {
            <div class="entry-row">
                <div class="entry-avatar">@player.Emoji</div>
                <span class="entry-name">@player.Name</span>
                <ScoreInput 
                    InputClass="score-value-warn"
                    Value="@(tempScores.GetValueOrDefault(player.PlayerId, 0))"
                    OnScoreAdjusted="@((int amount) => AdjustEditScore(player.PlayerId, amount))"
                    OnValueChanged="@((int val) => OnScoreInputChange(player.PlayerId, new ChangeEventArgs { Value = val }))" />
            </div>
        }
        
        <button class="validate-btn mt-15" @onclick="ConfirmEdit">✓ Confirmer le Tour @editingRound</button>
    </div>
}

@code {
    [Inject] public IJSRuntime JSRuntime { get; set; } = default!;

    private int maxCompletedRound = 0;
    private int editingRound = 1;
    private Dictionary<Guid, int> tempScores = new();
    private List<PlayerScore> leaderboard = new();

    protected override void OnInitialized()
    {
        if (GameState.CurrentSession != null)
        {
            maxCompletedRound = GameState.CurrentSession.Status == SessionStatus.Finished
                ? GameState.CurrentSession.CurrentRound
                : GameState.CurrentSession.CurrentRound - 1;

            if (maxCompletedRound > 0)
            {
                editingRound = maxCompletedRound; // Default to most recently completed round
                LoadRoundToEdit(editingRound);
                CalculateCurrentLeaderboard();
            }
        }
    }

    private void SelectRound(int round)
    {
        editingRound = round;
        LoadRoundToEdit(round);
        CalculateCurrentLeaderboard(); // Needed to reflect the change in selected round correctly
    }

    private async Task GoBack()
    {
        await JSRuntime.InvokeVoidAsync("goBack");
    }

    private void LoadRoundToEdit(int round)
    {
        tempScores.Clear();
        if (GameState.CurrentSession != null)
        {
            foreach (var player in GameState.CurrentSession.Players)
            {
                var entry = GameState.CurrentSession.Scores.FirstOrDefault(s => s.PlayerId == player.PlayerId && s.Round == round);
                tempScores[player.PlayerId] = entry?.Value ?? 0;
            }
        }
    }

    private void AdjustEditScore(Guid playerId, int amount)
    {
        if (tempScores.ContainsKey(playerId))
        {
            tempScores[playerId] += amount;
            CalculateCurrentLeaderboard(); // Recalculate leaderboard on every change for dynamic total preview
        }
    }

    private int GetScoreForRound(Guid playerId, int round)
    {
        if (GameState.CurrentSession == null) return 0;
        var entry = GameState.CurrentSession.Scores.FirstOrDefault(s => s.PlayerId == playerId && s.Round == round);
        return entry?.Value ?? 0;
    }

    private int GetProjectedTotalScore(Guid playerId)
    {
        if (GameState.CurrentSession == null) return 0;
        
        var actualScoresSum = GameState.CurrentSession.Scores
            .Where(s => s.PlayerId == playerId && s.Round <= maxCompletedRound && s.Round != editingRound)
            .Sum(s => s.Value);

        var editedScore = tempScores.GetValueOrDefault(playerId, 0);

        return actualScoresSum + editedScore;
    }

    private void CalculateCurrentLeaderboard()
    {
        if (GameState.CurrentSession == null) return;
        
        var playerIds = GameState.CurrentSession.Players.Select(p => p.PlayerId).ToList();
        
        var projectedScores = GameState.CurrentSession.Scores
            .Where(s => s.Round <= maxCompletedRound && s.Round != editingRound)
            .ToList();
        
        foreach (var kvp in tempScores)
        {
            projectedScores.Add(new ScoreEntry(Guid.NewGuid(), GameState.CurrentSession.Id, kvp.Key, editingRound, kvp.Value));
        }

        leaderboard = ScoreCalculator.CalculateLeaderboard(
            GameState.CurrentSession.Template.ScoreType,
            playerIds,
            projectedScores
        ).ToList();
    }

    private void OnScoreInputChange(Guid playerId, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var result))
        {
            tempScores[playerId] = result;
            CalculateCurrentLeaderboard();
        }
    }

    private async Task ConfirmEdit()
    {
        if (GameState.CurrentSession != null)
        {
            foreach (var kvp in tempScores)
            {
                await GameState.RecordScoreAsync(kvp.Key, editingRound, kvp.Value);
            }
        }
        await GoBack();
    }
}