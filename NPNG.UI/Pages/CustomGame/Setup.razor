@page "/custom-game"
@inject NavigationManager NavigationManager
@inject NPNG.Application.State.GameStateService GameState
@inject NPNG.Application.Interfaces.IGameCatalogueService GameCatalogueService

<div class="app-header">
    <div class="header-nav">
        <button class="ico-btn" @onclick="GoBack">←</button>
        <span style="font-size:1.05rem;font-weight:700">Jeu personnalisé</span>
    </div>
</div>

<div class="form-card">
    <div class="field-lbl">Nom du jeu</div>
    <input class="field-input" type="text" @bind="gameName" placeholder="Ex: Belote maison" />

    <div class="field-lbl">Qui gagne ?</div>
    <div class="toggle-row">
        <button class="toggle-opt @(winCondition == "high" ? "on" : "")" @onclick='() => SetWinCondition("high")'>🏆 Le + haut</button>
        <button class="toggle-opt @(winCondition == "low" ? "on" : "")" @onclick='() => SetWinCondition("low")'>🎯 Le + bas</button>
    </div>

    <div class="setting-row">
        <div class="field-lbl">Passage du 1er joueur</div>
        <label class="toggle-switch">
            <input type="checkbox" @bind="enableFirstPlayer" />
            <span class="toggle-slider"></span>
        </label>
    </div>

    @if (enableFirstPlayer)
    {
        <div class="toggle-row mechanic-row">
            <button class="toggle-opt @(firstPlayerMechanic == NPNG.Domain.Enums.FirstPlayerMechanic.Sequential ? "on" : "")" @onclick='() => SetFirstPlayerMechanic(NPNG.Domain.Enums.FirstPlayerMechanic.Sequential)'>🔄 Chacun son tour</button>
            <button class="toggle-opt @(firstPlayerMechanic == NPNG.Domain.Enums.FirstPlayerMechanic.Winner ? "on" : "")" @onclick='() => SetFirstPlayerMechanic(NPNG.Domain.Enums.FirstPlayerMechanic.Winner)'>🏆 Premier (Général)</button>
            <button class="toggle-opt @(firstPlayerMechanic == NPNG.Domain.Enums.FirstPlayerMechanic.Loser ? "on" : "")" @onclick='() => SetFirstPlayerMechanic(NPNG.Domain.Enums.FirstPlayerMechanic.Loser)'>🎯 Dernier (Général)</button>
            <button class="toggle-opt @(firstPlayerMechanic == NPNG.Domain.Enums.FirstPlayerMechanic.HighestInPreviousRound ? "on" : "")" @onclick='() => SetFirstPlayerMechanic(NPNG.Domain.Enums.FirstPlayerMechanic.HighestInPreviousRound)'>📈 + haut (Manche)</button>
            <button class="toggle-opt @(firstPlayerMechanic == NPNG.Domain.Enums.FirstPlayerMechanic.LowestInPreviousRound ? "on" : "")" @onclick='() => SetFirstPlayerMechanic(NPNG.Domain.Enums.FirstPlayerMechanic.LowestInPreviousRound)'>📉 + bas (Manche)</button>
        </div>
    }

    <div class="input-group-row">
        <div class="input-group-col">
            <div class="field-lbl">Limite de score (opt.)</div>
            <input class="field-input" type="number" @bind="scoreLimit" placeholder="ex : 500" />
        </div>

        <div class="input-group-col">
            <div class="field-lbl">Limite de tours (opt.)</div>
            <input class="field-input" type="number" @bind="roundLimit" placeholder="ex : 10" />
        </div>
    </div>
</div>

<div class="form-card">
    <div class="field-lbl">Incrément par défaut des boutons</div>
    <div class="toggle-row">
        <button class="toggle-opt @(incrementType == "1_10" ? "on" : "")" @onclick='() => SetIncrement("1_10")'>± 1 / ± 10</button>
        <button class="toggle-opt @(incrementType == "5_50" ? "on" : "")" @onclick='() => SetIncrement("5_50")'>± 5 / ± 50</button>
        <button class="toggle-opt @(incrementType == "free" ? "on" : "")" @onclick='() => SetIncrement("free")'>Libre</button>
    </div>
</div>

<div class="save-game-row">
    <input type="checkbox" id="saveGame" @bind="saveToCatalogue" class="save-game-checkbox" />
    <label for="saveGame" class="save-game-lbl">Sauvegarder ce modèle dans mon catalogue</label>
</div>

<div class="info-banner">
    💡 Tu pourras modifier ces règles entre deux parties depuis les paramètres.
</div>

<button class="btn-cta" disabled="@string.IsNullOrWhiteSpace(gameName)" @onclick="CreateGame">
    Créer ce jeu →
</button>

@code {
    [Inject] public IJSRuntime JSRuntime { get; set; } = default!;

    private string gameName = "Belote maison";
    private string winCondition = "high";
    private string scoreLimit = "";
    private string roundLimit = "";
    private string incrementType = "1_10";
    private bool enableFirstPlayer = true;
    private NPNG.Domain.Enums.FirstPlayerMechanic firstPlayerMechanic = NPNG.Domain.Enums.FirstPlayerMechanic.Sequential;
    private bool saveToCatalogue = false;

    [SupplyParameterFromQuery(Name = "baseGameId")]
    public Guid? BaseGameId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (BaseGameId.HasValue)
        {
            var games = await GameCatalogueService.GetAvailableGamesAsync();
            var baseGame = games.FirstOrDefault(g => g.Id == BaseGameId.Value);

            if (baseGame != null)
            {
                gameName = baseGame.Name;
                winCondition = baseGame.ScoreType == NPNG.Domain.Enums.ScoreType.CumulativeLower ? "low" : "high";
                
                if (baseGame.Rules != null)
                {
                    scoreLimit = baseGame.Rules.TargetScore?.ToString() ?? "";
                    roundLimit = baseGame.Rules.MaxRounds?.ToString() ?? "";
                    firstPlayerMechanic = baseGame.Rules.FirstPlayerMechanic;
                    
                    if (firstPlayerMechanic == NPNG.Domain.Enums.FirstPlayerMechanic.None)
                    {
                        enableFirstPlayer = false;
                        firstPlayerMechanic = NPNG.Domain.Enums.FirstPlayerMechanic.Sequential; // Keep a default selected if toggled on later
                    }
                }
            }
        }
    }

    private async Task GoBack()
    {
        await JSRuntime.InvokeVoidAsync("goBack");
    }

    private void SetWinCondition(string condition)
    {
        winCondition = condition;
    }

    private void SetFirstPlayerMechanic(NPNG.Domain.Enums.FirstPlayerMechanic mechanic)
    {
        firstPlayerMechanic = mechanic;
    }

    private void SetIncrement(string type)
    {
        incrementType = type;
    }

    private async Task CreateGame()
    {
        if (string.IsNullOrWhiteSpace(gameName)) return;
        
        var scoreType = winCondition == "high" ? NPNG.Domain.Enums.ScoreType.Cumulative : NPNG.Domain.Enums.ScoreType.CumulativeLower;
        
        int? parsedScoreLimit = int.TryParse(scoreLimit, out var s) ? s : null;
        int? parsedRoundLimit = int.TryParse(roundLimit, out var r) ? r : null;
        
        var finalMechanic = enableFirstPlayer ? firstPlayerMechanic : NPNG.Domain.Enums.FirstPlayerMechanic.None;
        var rules = new NPNG.Domain.Entities.GameRules(TargetScore: parsedScoreLimit, MaxRounds: parsedRoundLimit, FirstPlayerMechanic: finalMechanic);

        var template = new NPNG.Domain.Entities.GameTemplate(Guid.NewGuid(), gameName.Trim(), scoreType, "Jeu personnalisé", rules);
        
        if (saveToCatalogue)
        {
            await GameCatalogueService.SaveCustomGameAsync(template, "var(--warn)");
        }
        
        await GameState.InitializeNewSessionAsync(template);
        
        NavigationManager.NavigateTo($"players?game={Uri.EscapeDataString(gameName.Trim())}");
    }
}
