@inject GameStateService GameState
@implements IDisposable

<div class="nav">
    <NavLink class="ni" href="" Match="NavLinkMatch.All" ActiveClass="on">
        <span class="ico">🏠</span>
        <span class="lbl">Accueil</span>
        <div class="ndot"></div>
    </NavLink>
    
    @if (HasActiveSession)
    {
        <NavLink class="ni" href="session" ActiveClass="on">
            <span class="ico">🎮</span>
            <span class="lbl">Partie</span>
            <div class="ndot"></div>
        </NavLink>
    }
    else
    {
        <div class="ni" style="opacity: 0.5; cursor: not-allowed;">
            <span class="ico" style="filter: grayscale(1);">🎮</span>
            <span class="lbl">Partie</span>
            <div class="ndot"></div>
        </div>
    }
    
    <NavLink class="ni" href="history" ActiveClass="on">
        <span class="ico">📋</span>
        <span class="lbl">Histo.</span>
        <div class="ndot"></div>
    </NavLink>
    
    <NavLink class="ni" href="settings" ActiveClass="on">
        <span class="ico">⚙️</span>
        <span class="lbl">Réglages</span>
        <div class="ndot"></div>
    </NavLink>
</div>

@code {
    private bool HasActiveSession => GameState.CurrentSession != null && GameState.CurrentSession.Status == SessionStatus.Active;

    protected override async Task OnInitializedAsync()
    {
        GameState.OnStateChanged += StateHasChanged;
        
        if (GameState.CurrentSession == null)
        {
            await GameState.LoadLatestActiveSessionAsync();
        }
    }

    public void Dispose()
    {
        GameState.OnStateChanged -= StateHasChanged;
    }
}
